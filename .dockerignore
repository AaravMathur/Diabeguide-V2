# Exclude node_modules from being copied into the containers
**/node_modules
node_modules
backend/node_modules

# Exclude compiled output
**/dist
dist
backend/dist

# Exclude local env configs
**/.env
.env
backend/.env

# Version control and logs
.git
.gitignore
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
